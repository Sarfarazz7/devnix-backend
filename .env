# Devnix backend config — copy to .env (already done)

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/devnix

# JWT
JWT_SECRET=devnix_super_secret_change_me_in_production_32chars_min
JWT_EXPIRES_IN=30d

# Server
PORT=3001

# NODE_ENV: leave as 'development' locally — CORS allows ALL localhost ports
NODE_ENV=development

# Production only: comma-separated frontend URLs
# CLIENT_ORIGINS=https://yourapp.com
