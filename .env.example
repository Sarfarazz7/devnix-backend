# ── Devnix Environment Config ──────────────────────────────
# Copy this file to .env and fill in your real values

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/devnix
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/devnix
MONGO_URI=mongodb://127.0.0.1:27017/devnix

# JWT secret — change to a long random string in production
JWT_SECRET=devnix_super_secret_change_me_in_production

# JWT expiry (e.g. 7d, 30d, 1y)
JWT_EXPIRES_IN=30d

# Server port
PORT=3001

# Client origin for CORS (your frontend URL)
CLIENT_ORIGIN=http://localhost:5500
